# Hermes Agent Modal deployment configuration
#
# Store the real values in a Modal Secret, for example:
#   modal secret create custom-secret ^
#     DEFAULT_MODEL=openrouter/free ^
#     OPENROUTER_API_KEY=... ^
#     TELEGRAM_BOT_TOKEN=... ^
#     TELEGRAM_WEBHOOK_SECRET=... ^
#     WEBHOOK_SECRET=...

# Modal deployment resources
HERMES_MODAL_APP_NAME=hermes-agent
HERMES_MODAL_SECRET_NAME=custom-secret
HERMES_MODAL_VOLUME_NAME=hermes-agent-data
HERMES_MODAL_DATA_DIR=/data/hermes
HERMES_MODAL_CONFIG_SOURCE=/root/config.modal.yaml
HERMES_MODAL_SYNC_CONFIG=true

# Hermes runtime
HERMES_HOME=/data/hermes-home
DEFAULT_MODEL=openrouter/free
HERMES_MAX_TURNS=16
AGENT_MAX_TOKENS=8192
HERMES_SESSION_ROUTE_TTL_SECONDS=7200
TERMINAL_ENV=local
HERMES_MODAL_TERMINAL_ENV=local

# Provider config
# Prefer Hermes/OpenRouter/OpenAI-compatible env vars over hard-coded endpoints.
HERMES_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace_me
OPENROUTER_BROADCAST_ENABLED=false
OPENROUTER_BROADCAST_PRIVACY_MODE=true
SUPERMEMORY_API_KEY=replace_me
# Optional: override the default "hermes" container tag used by the official
# Hermes supermemory memory provider integration.
# SUPERMEMORY_CONTAINER_TAG=hermes

# Optional toolset tuning
# HERMES_ENABLED_TOOLSETS=web,file,terminal,todo,memory,session_search
HERMES_DISABLED_TOOLSETS=browser,messaging,rl,voice

# Official integrations
# Enable project-local plugins from ./.hermes/plugins/ (official plugin system).
HERMES_ENABLE_PROJECT_PLUGINS=true

# Web search backends (official integrations docs: Firecrawl / Parallel / Tavily / Exa)
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=
# PARALLEL_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=

# Browser integrations
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSER_USE_API_KEY=
# FIRECRAWL_BROWSER_SESSION_TTL=300
# CAMOFOX_URL=http://localhost:9377

# Home Assistant integration
# HASS_URL=https://homeassistant.example.com
# HASS_TOKEN=

# OpenAI-compatible API server integration
# API_SERVER_ENABLED=false
# API_SERVER_KEY=
# API_SERVER_PORT=8000
# API_SERVER_HOST=127.0.0.1

# Public webhook protection
# Used by the generic /invoke endpoint as Bearer auth.
WEBHOOK_SECRET=replace_me

# Telegram webhook support
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_WEBHOOK_SECRET=replace_me
HERMES_PUBLIC_BASE_URL=https://isuyee88--hermes-agent-web-app.modal.run
TELEGRAM_WEBHOOK_AUTO_SYNC=true
TELEGRAM_SEND_ACK=false

# QQ official bot webhook support
QQ_APP_ID=replace_me
QQ_APP_SECRET=replace_me
# Optional:
# QQ_ALLOWED_USERS=
# QQ_HOME_CHANNEL=c2c:USER_OPENID

# Feishu / Lark support
FEISHU_APP_ID=replace_me
FEISHU_APP_SECRET=replace_me
# Optional:
# FEISHU_DOMAIN=feishu
# FEISHU_CONNECTION_MODE=webhook
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_BITABLE_APP_TOKEN=
# FEISHU_BITABLE_TABLE_ID=
# FEISHU_MODEL_REGISTRY_MIRROR_ENABLED=false
# FEISHU_ALLOWED_USERS=
# FEISHU_HOME_CHANNEL=
# HERMES_FEISHU_RESOLVE_SENDER_NAMES=false
# HERMES_FEISHU_MENU_OPEN_BY_OPEN_ID=true
# HERMES_FEISHU_TOOL_CAPABILITIES=docs,sheets,bitable,contacts,messages,files,model_registry
# HERMES_FEISHU_DEFAULT_WORKSPACE=
