# Hermes Agent LLM Configuration
# Configure LLM providers and API keys

# ============================================
# ANTHROPIC (Claude Models)
# ============================================
ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxx"

# ============================================
# OPENAI (GPT Models)
# ============================================
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# ============================================
# CUSTOM LLM ENDPOINT (OpenAI-compatible)
# ============================================
# For Cloudflare AI Gateway or other custom endpoints
CUSTOM_LLM_ENDPOINT="https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_ID/v1"
CUSTOM_LLM_API_KEY="xxxxxxxxxxxx"

# ============================================
# CLOUDFLARE AI GATEWAY
# ============================================
CLOUDFLARE_AI_GATEWAY_BASE_URL="https://gateway.ai.cloudflare.com/v1/d1215a30b84b673ef0367010b0e78c10/affiliate-manager"
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token_here"

# ============================================
# DEFAULT MODEL CONFIGURATION
# ============================================
DEFAULT_MODEL="anthropic/claude-sonnet-4-20250514"
AGENT_MAX_TOKENS=8192
AGENT_TEMPERATURE=0.7

# ============================================
# OPENROUTER (Alternative)
# ============================================
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxx"
